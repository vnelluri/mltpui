# Local dev (no Docker) config — used by `python scripts/dev.py`, which
# copies this to backend/.env on first run. Independent of the repo-root
# .env.example (that one is for the Docker/LocalStack path — the two do
# not interact; use whichever local-dev path you prefer).
#
# ── Auth ──────────────────────────────────────────────────────────────────────
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
# Only needed in prod for group-overage users (>200 AD groups): lets the API
# fetch memberships from Microsoft Graph (GroupMember.Read.All, admin consent).
ENTRA_CLIENT_SECRET=
ENTRA_AUDIENCE=api://ml-training-platform

# AUTH_MODE controls backend auth behaviour:
#   prod  → validate real Entra ID JWT (requires ENTRA_* vars above)
#   dev   → skip JWT validation; inject a synthetic user from DEV_USER_* vars below
AUTH_MODE=dev

# Synthetic user injected when AUTH_MODE=dev. Change to test different roles.
# Roles: PlatformAdmin | TenantAdmin | DataScientist | MRM
# NOTE: env vars are read once at process startup — after editing this,
# stop scripts/dev.py (Ctrl+C) and re-run it. A plain file edit alone has
# no effect until the process restarts.
DEV_USER_ID=dev-user-001
DEV_USER_EMAIL=dev@local.test
DEV_USER_NAME=Dev User
DEV_USER_ROLE=PlatformAdmin
# Ignored when role is PlatformAdmin.
DEV_USER_TENANT_ID=tenant-risk-analytics
# Optional extra memberships (comma-separated Role:tenantId) to exercise the
# topbar role/tenant switcher locally.
DEV_USER_MEMBERSHIPS=

# ── Group-name convention (prod identity) ────────────────────────────────────
# Role/tenant are DERIVED from Entra security-group NAMES — no mapping table.
GROUP_NAME_PATTERN=^myapp-(?P<tenant>[a-z0-9][a-z0-9-]*?)-(?P<role>datascientist|tenantadmin)$
GROUP_NAME_PLATFORM_ADMIN=myapp-platform-admin
GROUP_NAME_MRM=myapp-platform-mrm

# ── Backend misc ──────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=["http://localhost:3000"]

# ── AWS (real deployment) ─────────────────────────────────────────────────────
AWS_REGION=us-east-1
# Leave both blank for local dev (moto doesn't check credentials) or when
# using an instance profile in ECS. NOTE: python-dotenv does not reliably
# strip an inline "# comment" on a line whose value is empty — the comment
# text itself can end up as the value — so keep any such note on its own
# line above, never trailing an empty `KEY=`.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── moto (local AWS emulation — replaces LocalStack, no Docker needed) ───────
# scripts/dev.py starts `python -m moto.server -p 5000` for you. Every
# *_ENDPOINT_URL below points at it. Leave all of them blank for real AWS.
DYNAMODB_TABLE_NAME=ml-platform
DYNAMODB_ENDPOINT_URL=http://localhost:5000
S3_ENDPOINT_URL=http://localhost:5000
S3_ARTIFACTS_BUCKET=ml-platform-artifacts
# true: skip the S3 existence check on model-registry artifact URIs (format
# checks still apply). Testing convenience only — never enable in prod.
ARTIFACT_URI_MOCK_MODE=false
KMS_ENDPOINT_URL=http://localhost:5000
SECRETS_MANAGER_ENDPOINT_URL=http://localhost:5000
STS_ENDPOINT_URL=http://localhost:5000
SECRETS_MANAGER_JOB_TOKEN_PREFIX=ml-platform/job-tokens/

# ── Control-plane / dataplane account split ──────────────────────────────────
# Blank = single-account/local. Set to the dataplane runtime role ARN to run
# split: EMR + job-secret calls assume it with tenantId session tags.
DATAPLANE_RUNTIME_ROLE_ARN=

# ── EMR Serverless ────────────────────────────────────────────────────────────
# DEPRECATED / fallback for legacy job records — EMR apps are per-tenant.
EMR_SERVERLESS_APPLICATION_ID=
EMR_MOCK_MODE=true
# EMR Studio (SSO-mode notebook workspace) — a DIFFERENT resource from the
# Serverless application above. Provisioned separately; the app only
# deep-links into it. Set its access URL.
EMR_STUDIO_URL=

# ── SageMaker ─────────────────────────────────────────────────────────────────
SAGEMAKER_DOMAIN_ID=
SAGEMAKER_TRAINING_IMAGE=
SAGEMAKER_MOCK_MODE=true

# ── Tenant provisioning ───────────────────────────────────────────────────────
TENANT_PROVISIONING_MOCK_MODE=true
TENANT_PROVISIONING_EVENT_BUS=default

# ── Snowflake OAuth ───────────────────────────────────────────────────────────
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_OAUTH_INTEGRATION_NAME=ml_platform_oauth
SNOWFLAKE_TOKEN_URL=
SNOWFLAKE_OAUTH_CLIENT_ID=
SNOWFLAKE_OAUTH_CLIENT_SECRET=
SNOWFLAKE_DEFAULT_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_DEFAULT_ROLE=ML_PLATFORM_ROLE
SNOWFLAKE_TOKEN_MIN_REMAINING_MINUTES=10
SNOWFLAKE_MOCK_MODE=true

# ── KMS (Snowflake token encryption) ─────────────────────────────────────────
# Single-account fallback key. In the account split each tenant has its own
# dataplane key (Tenant.kmsKeyArn), which takes precedence — leave this blank.
KMS_SNOWFLAKE_KEY_ARN=

# ── Run tokens / API URL (machine identity for training jobs) ─────────────────
RUN_TOKEN_TTL_HOURS=26
PLATFORM_API_BASE_URL=