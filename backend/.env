# Local dev (no Docker) config — used by `python scripts/dev.py`, which
# copies this to backend/.env on first run. Independent of the repo-root
# .env.example (that one is for the Docker/LocalStack path — the two do
# not interact; use whichever local-dev path you prefer).
#
# ── Auth ──────────────────────────────────────────────────────────────────────
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_AUDIENCE=api://ml-training-platform

# AUTH_MODE controls backend auth behaviour:
#   prod  → validate real Entra ID JWT (requires ENTRA_* vars above)
#   dev   → skip JWT validation; inject a synthetic user from DEV_USER_* vars below
AUTH_MODE=dev

# Synthetic user injected when AUTH_MODE=dev. Change to test different roles.
# Roles: PlatformAdmin | TenantAdmin | DataScientist | MRM
# NOTE: env vars are read once at process startup — after editing this,
# stop scripts/dev.py (Ctrl+C) and re-run it. A plain file edit alone has
# no effect until the process restarts.
DEV_USER_ID=dev-user-001
DEV_USER_EMAIL=dev@local.test
DEV_USER_NAME=Dev User
DEV_USER_ROLE=DataScientist
DEV_USER_TENANT_ID=tenant-risk-analytics   # ignored when role is PlatformAdmin

# ── Backend misc ──────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=["http://localhost:3000"]

# ── AWS (real deployment) ─────────────────────────────────────────────────────
AWS_REGION=us-east-1
# Leave both blank for local dev (moto doesn't check credentials) or when
# using an instance profile in ECS. NOTE: python-dotenv does not reliably
# strip an inline "# comment" on a line whose value is empty — the comment
# text itself can end up as the value — so keep any such note on its own
# line above, never trailing an empty `KEY=`.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── moto (local AWS emulation — replaces LocalStack, no Docker needed) ───────
# scripts/dev.py starts `python -m moto.server -p 5000` for you. Every
# *_ENDPOINT_URL below points at it. Leave all of them blank for real AWS.
DYNAMODB_TABLE_NAME=ml-platform
DYNAMODB_ENDPOINT_URL=http://localhost:5000
S3_ENDPOINT_URL=http://localhost:5000
S3_ARTIFACTS_BUCKET=ml-platform-artifacts
KMS_ENDPOINT_URL=http://localhost:5000
SECRETS_MANAGER_ENDPOINT_URL=http://localhost:5000
SECRETS_MANAGER_JOB_TOKEN_PREFIX=ml-platform/job-tokens/

# ── EMR Serverless ────────────────────────────────────────────────────────────
EMR_SERVERLESS_APPLICATION_ID=
EMR_MOCK_MODE=true
# EMR Studio (notebook workspace) — a DIFFERENT resource from the Serverless
# application above. Must be provisioned separately (AWS Console/IaC); this
# app only requests a presigned login URL into it, never creates it.
EMR_STUDIO_ID=

# ── SageMaker ─────────────────────────────────────────────────────────────────
SAGEMAKER_EXECUTION_ROLE_ARN=
SAGEMAKER_DOMAIN_ID=
SAGEMAKER_MOCK_MODE=true

# ── Snowflake OAuth ───────────────────────────────────────────────────────────
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_OAUTH_INTEGRATION_NAME=ml_platform_oauth
SNOWFLAKE_TOKEN_URL=
SNOWFLAKE_OAUTH_CLIENT_ID=
SNOWFLAKE_OAUTH_CLIENT_SECRET=
SNOWFLAKE_DEFAULT_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_MOCK_MODE=true

# ── KMS (Snowflake token encryption) ─────────────────────────────────────────
KMS_SNOWFLAKE_KEY_ARN=

# Demo data seeding on dev.py startup (set true to restore seeded demo data)
SEED_DEMO_DATA=false

# Extra dev memberships (role:tenant, comma-separated) — enables the topbar
# role switcher so the full DS -> MRM -> TenantAdmin flow is testable without
# restarts. Platform-wide roles (MRM) take no tenant.
DEV_USER_MEMBERSHIPS=MRM:,TenantAdmin:tenant-risk-analytics
