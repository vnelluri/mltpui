# ── Auth ──────────────────────────────────────────────────────────────────────
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
# Only needed in prod for group-overage users (>200 AD groups): lets the API
# fetch memberships from Microsoft Graph (GroupMember.Read.All, admin consent).
ENTRA_CLIENT_SECRET=
ENTRA_AUDIENCE=api://ml-training-platform

# AUTH_MODE controls backend auth behaviour:
#   prod  → validate real Entra ID JWT (requires ENTRA_* vars above)
#   dev   → skip JWT validation; inject a synthetic user from DEV_USER_* vars below
AUTH_MODE=dev

# Synthetic user injected when AUTH_MODE=dev. Change to test different roles.
# Roles: PlatformAdmin | TenantAdmin | DataScientist | MRM
DEV_USER_ID=dev-user-001
DEV_USER_EMAIL=dev@local.test
DEV_USER_NAME=Dev User
DEV_USER_ROLE=PlatformAdmin
DEV_USER_TENANT_ID=tenant-risk-analytics   # ignored when role is PlatformAdmin
# Optional extra memberships (comma-separated Role:tenantId) so the topbar
# role/tenant switcher can be exercised locally, e.g.:
# DEV_USER_MEMBERSHIPS=DataScientist:tenant-risk-analytics,DataScientist:tenant-fraud-detection
DEV_USER_MEMBERSHIPS=

# ── Group-name convention (prod identity) ────────────────────────────────────
# Role/tenant are DERIVED from Entra security-group NAMES — no mapping table.
# Tenant-scoped groups must match GROUP_NAME_PATTERN (named captures `tenant`
# and `role`); the two platform-wide roles use the fixed names below.
# SECURITY: creation of matching group names must be reserved to your governed
# IGA process — the name IS the access grant.
GROUP_NAME_PATTERN=^myapp-(?P<tenant>[a-z0-9][a-z0-9-]*?)-(?P<role>datascientist|tenantadmin)$
GROUP_NAME_PLATFORM_ADMIN=myapp-platform-admin
GROUP_NAME_MRM=myapp-platform-mrm

# ── Backend misc ──────────────────────────────────────────────────────────────
# Origins allowed to call the API from a browser (JSON array). Local frontend runs
# on port 3000.
CORS_ALLOWED_ORIGINS=["http://localhost:3000"]

# ── AWS (real deployment) ─────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=                         # leave blank when using instance profile in ECS
AWS_SECRET_ACCESS_KEY=

# ── DynamoDB ──────────────────────────────────────────────────────────────────
DYNAMODB_TABLE_NAME=ml-platform
# Set to LocalStack endpoint for local dev; leave blank for real AWS
DYNAMODB_ENDPOINT_URL=http://localstack:4566

# ── S3 ────────────────────────────────────────────────────────────────────────
S3_ENDPOINT_URL=http://localstack:4566     # leave blank for real AWS
S3_ARTIFACTS_BUCKET=ml-platform-artifacts

# ── EMR Serverless ────────────────────────────────────────────────────────────
# DEPRECATED / local-dev fallback only. Each tenant has its own EMR Serverless
# application (Tenant.emrApplicationId) written back by the provisioning
# pipeline; this value is only used for legacy job records.
EMR_SERVERLESS_APPLICATION_ID=
# When blank in dev mode, job submission returns a fake jobRunId instead of
# calling real EMR, so the full job creation flow can be tested locally.
EMR_MOCK_MODE=true
# EMR Studio (notebook workspace) — a DIFFERENT resource from the Serverless
# application above. Provision it separately in SSO auth mode (users' Entra
# identity flows through natively, keeping notebook activity attributable)
# and set its access URL; the app only deep-links into it.
EMR_STUDIO_URL=

# ── SageMaker ─────────────────────────────────────────────────────────────────
# Execution roles are per-tenant (Tenant.executionRoleArn, from the
# provisioning pipeline) — there is no platform-wide execution-role variable.
SAGEMAKER_DOMAIN_ID=
# Training container image for real SageMaker training jobs (platform-wide).
SAGEMAKER_TRAINING_IMAGE=
# When true in dev mode, notebook launch returns a fake presigned URL.
SAGEMAKER_MOCK_MODE=true

# ── Control-plane / dataplane account split ──────────────────────────────────
# Leave blank for local dev and single-account deployments. Set to the
# dataplane account's ml-platform-dataplane-runtime role ARN to run split:
# EMR + job-secret calls then assume it with tenantId session tags (ABAC).
DATAPLANE_RUNTIME_ROLE_ARN=
STS_ENDPOINT_URL=http://localstack:4566   # LocalStack only; blank in AWS

# ── Tenant provisioning ───────────────────────────────────────────────────────
# true (local dev): POST /tenants self-provisions mock dataplane resource IDs
#   and goes straight to provisioningStatus=active.
# false (prod): POST /tenants emits a TenantProvisioningRequested event to
#   EventBridge; the IaC pipeline creates the tenant's EMR app / execution
#   role / S3 prefix and reports back via PUT /tenants/{id}/provisioning.
TENANT_PROVISIONING_MOCK_MODE=true
TENANT_PROVISIONING_EVENT_BUS=default

# ── Snowflake OAuth ───────────────────────────────────────────────────────────
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_OAUTH_INTEGRATION_NAME=ml_platform_oauth
SNOWFLAKE_TOKEN_URL=
SNOWFLAKE_OAUTH_CLIENT_ID=
SNOWFLAKE_OAUTH_CLIENT_SECRET=
SNOWFLAKE_DEFAULT_WAREHOUSE=COMPUTE_WH
# Snowflake ROLE requested in the token-exchange scope (session:role:<this>).
# Must match the role setup_snowflake_integration.sql creates/pre-authorizes.
SNOWFLAKE_DEFAULT_ROLE=ML_PLATFORM_ROLE
# Minimum token validity (minutes) required when submitting a Snowflake-backed
# job — fails fast instead of dying mid-job on an about-to-expire token.
SNOWFLAKE_TOKEN_MIN_REMAINING_MINUTES=10
SNOWFLAKE_MOCK_MODE=true

# ── KMS (Snowflake token encryption) ─────────────────────────────────────────
KMS_SNOWFLAKE_KEY_ARN=
KMS_ENDPOINT_URL=http://localstack:4566

# ── Secrets Manager (Snowflake token transit to EMR/SageMaker) ───────────────
SECRETS_MANAGER_ENDPOINT_URL=http://localstack:4566
SECRETS_MANAGER_JOB_TOKEN_PREFIX=ml-platform/job-tokens/

# ── Frontend ──────────────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000
VITE_ENTRA_TENANT_ID=
VITE_ENTRA_CLIENT_ID=
VITE_DEMO_MODE=true
